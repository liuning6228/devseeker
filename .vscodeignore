.vscode/**
.vscode-test/**
src/**
out/**/*.map

# ─── node_modules 默认排除，再按需保留 ───
node_modules/**

# @huggingface/transformers（含 WASM + ONNX 模型资源 + 嵌套 onnxruntime-node）
!node_modules/@huggingface/**
# @huggingface 嵌套 onnxruntime-node 的非目标平台由 vsce-package.mjs 动态裁剪，
# 这里不做硬编码排除，避免跨平台打包时误删

# web-tree-sitter（WASM）
!node_modules/web-tree-sitter/**
# tree-sitter-wasms（WASM）
!node_modules/tree-sitter-wasms/**
# @vscode/codicons（字体图标）
!node_modules/@vscode/codicons/dist/codicon.css
!node_modules/@vscode/codicons/dist/codicon.ttf

# 全局排除跨平台二进制（由 vsce-package.mjs 动态保留目标平台）
node_modules/sharp/**
node_modules/pino-pretty/**

# ─── 离线 BERT 模型（必须包含） ───
!models/**

# ─── DevSeeker 技能（保留 SKILL.md） ───
.my-agent/**
!.my-agent/skills/**
!.my-agent/skills/*/SKILL.md

# ─── 排除开发 / CI 垃圾 ───
.gitignore
.eslintrc.*
**/tsconfig*.json
esbuild.mjs
docs/**
tests/**
webview-ui/src/**
webview-ui/node_modules/**
webview-ui/package.json
webview-ui/tsconfig.json
webview-ui/vite.config.ts
**/*.test.ts
**/*.test.js
**/vitest.config.*
coverage/**
tmp/**
test-out.log
scripts/**
.dualmind/
.devseeker/**
