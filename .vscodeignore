.vscode/**
.vscode-test/**
src/**
out/**/*.map

# ─── node_modules 默认排除，再按需保留 ───
node_modules/**

# @huggingface/transformers（含 WASM + ONNX 模型资源）
!node_modules/@huggingface/**

# web-tree-sitter（WASM）
!node_modules/web-tree-sitter/**
# tree-sitter-wasms（WASM）
!node_modules/tree-sitter-wasms/**
# better-sqlite3（原生 SQLite 绑定）
!node_modules/better-sqlite3/**
# sql.js（WASM SQLite，fallback）
!node_modules/sql.js/**

# 排除 sharp（图片处理原生模块，可选依赖）
node_modules/sharp/**
node_modules/@img/**

# 排除 pino-pretty（仅开发模式使用）
node_modules/pino-pretty/**

# ─── 离线 BERT 模型（必须包含） ───
!models/**

# ─── DevSeeker 技能（保留 SKILL.md） ───
.my-agent/**
!.my-agent/skills/**
!.my-agent/skills/*/SKILL.md

# ─── 排除开发 / CI 垃圾 ───
.gitignore
.eslintrc.*
**/tsconfig*.json
esbuild.mjs
docs/**
tests/**
webview-ui/src/**
webview-ui/node_modules/**
webview-ui/package.json
webview-ui/tsconfig.json
webview-ui/vite.config.ts
**/*.test.ts
**/*.test.js
**/vitest.config.*
coverage/**
tmp/**
test-out.log
scripts/**
.dualmind/
.devseeker/**
